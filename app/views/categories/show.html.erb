<% content_for :title, "#{@category.name} — Categoria" %>

<div class="flex items-center justify-between mb-6">
  <div class="flex items-center gap-3">
    <%= category_dot(@category, size: 14) %>
    <h1 class="text-3xl"><%= @category.name %></h1>
  </div>
  <div class="space-x-2">
    <%= link_to "Editar", edit_category_path(@category), class: "btn-secondary" %>
    <%= link_to "Voltar", categories_path, class: "btn-ghost" %>
  </div>
</div>

<h2 class="text-sm uppercase tracking-widest text-ink-200 mb-3">Últimos lançamentos</h2>

<% if @recent_transactions.any? %>
  <div class="card p-0 overflow-hidden">
    <table class="table">
      <thead><tr><th>Data</th><th>Descrição</th><th>Tipo</th><th class="text-right">Valor</th></tr></thead>
      <tbody>
        <% @recent_transactions.each do |t| %>
          <tr>
            <td><%= l(t.date, format: :long) %></td>
            <td><%= t.description.presence || "—" %></td>
            <td>
              <span class="<%= t.income? ? 'badge-income' : 'badge-expense' %>">
                <%= t.income? ? "Receita" : "Despesa" %>
              </span>
            </td>
            <td class="text-right font-mono"><%= brl(t.amount) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="card text-center py-10">
    <p class="text-ink-200">Nenhum lançamento nessa categoria ainda.</p>
  </div>
<% end %>
