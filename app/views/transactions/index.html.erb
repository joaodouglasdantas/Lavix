<% content_for :title, "Lançamentos — Lavix" %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-3xl">Lançamentos</h1>
    <p class="text-ink-200 text-sm mt-1">Receitas e despesas registradas na sua conta.</p>
  </div>
  <%= link_to "Novo lançamento", new_transaction_path, class: "btn-primary" %>
</div>

<div class="card mb-6">
  <%= form_with url: transactions_path, method: :get, class: "grid grid-cols-1 sm:grid-cols-3 gap-4 items-end" do %>
    <div>
      <label class="form-label">Tipo</label>
      <select name="kind" class="form-select">
        <option value="">Todos</option>
        <option value="income"  <%= "selected" if params[:kind] == "income" %>>Receitas</option>
        <option value="expense" <%= "selected" if params[:kind] == "expense" %>>Despesas</option>
      </select>
    </div>
    <div>
      <label class="form-label">Categoria</label>
      <select name="category_id" class="form-select">
        <option value="">Todas</option>
        <% current_user.categories.alphabetical.each do |c| %>
          <option value="<%= c.id %>" <%= "selected" if params[:category_id].to_s == c.id.to_s %>><%= c.name %></option>
        <% end %>
      </select>
    </div>
    <div class="flex gap-2">
      <button class="btn-primary">Filtrar</button>
      <%= link_to "Limpar", transactions_path, class: "btn-ghost" %>
    </div>
  <% end %>
</div>

<% if @transactions.any? %>
  <div class="card p-0 overflow-hidden">
    <table class="table">
      <thead>
        <tr>
          <th>Data</th>
          <th>Descrição</th>
          <th>Categoria</th>
          <th>Tipo</th>
          <th class="text-right">Valor</th>
          <th class="w-32 text-right">Ações</th>
        </tr>
      </thead>
      <tbody>
        <% @transactions.each do |t| %>
          <tr>
            <td class="whitespace-nowrap"><%= l(t.date, format: :long) %></td>
            <td><%= t.description.presence || "—" %></td>
            <td>
              <div class="flex items-center gap-2">
                <%= category_dot(t.category) %>
                <span><%= t.category.name %></span>
              </div>
            </td>
            <td>
              <span class="<%= t.income? ? 'badge-income' : 'badge-expense' %>">
                <%= t.income? ? "Receita" : "Despesa" %>
              </span>
            </td>
            <td class="text-right font-mono <%= t.income? ? 'text-emerald-300' : 'text-red-300' %>">
              <%= t.income? ? "+" : "−" %> <%= brl(t.amount) %>
            </td>
            <td class="text-right space-x-1 whitespace-nowrap">
              <%= link_to "Editar", edit_transaction_path(t), class: "btn-secondary text-xs py-1 px-2" %>
              <%= button_to "×", transaction_path(t), method: :delete,
                    class: "btn-danger text-xs py-1 px-2 inline-flex",
                    data: { turbo_confirm: "Excluir lançamento?" }, form: { class: "inline" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="card text-center py-16">
    <p class="text-ink-200">Nenhum lançamento encontrado.</p>
    <%= link_to "Criar primeiro lançamento", new_transaction_path, class: "btn-primary mt-4" %>
  </div>
<% end %>
